# Primary promotions runtime contract.
PROMOTIONS_MSSQL_SERVER=your-server-name
PROMOTIONS_MSSQL_DATABASE=your-database-name
# Leave blank unless SQL authentication is required.
PROMOTIONS_MSSQL_USERNAME=
PROMOTIONS_MSSQL_PASSWORD=
PROMOTIONS_MSSQL_DRIVER=ODBC Driver 18 for SQL Server
PROMOTIONS_MSSQL_ENCRYPT=yes
PROMOTIONS_MSSQL_TRUST_SERVER_CERTIFICATE=yes
PROMOTIONS_ADVICE_TABLE=promotions
PROMOTIONS_PWLOGD_TABLE=PwlogD
PROMOTIONS_SCHEMA=dbo
# Must be an absolute governed path outside the repository root.
PROMOTIONS_NAS_ROOT=/Volumes/your-nas/promotions
# Optional local review copy for one operator-friendly inspection package per run.
PROMOTIONS_LOCAL_INSPECTION_ROOT=tmp/promotions_local_inspection
# Set to no to disable the local inspection copy.
PROMOTIONS_ENABLE_LOCAL_INSPECTION_COPY=yes
