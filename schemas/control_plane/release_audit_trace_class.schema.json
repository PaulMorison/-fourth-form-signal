{
  "type": "object",
  "required": [
    "release_audit_trace_class_id",
    "description",
    "allowed_contained_rollback_statuses",
    "allowed_contained_rollback_outcomes",
    "allow_release_audit_trace_restrictions",
    "allow_release_audit_trace_prerequisite_deferral",
    "prohibited_release_audit_trace_fields",
    "status",
    "lineage"
  ],
  "properties": {
    "release_audit_trace_class_id": {
      "type": "string",
      "min_length": 1
    },
    "description": {
      "type": "string",
      "min_length": 1
    },
    "allowed_contained_rollback_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
